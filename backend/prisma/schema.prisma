// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 枚举类型定义
enum UserRole {
  USER
  ADMIN
  MODERATOR
  CREATOR
}

enum AnalysisType {
  TEXT
  IMAGE
}

enum AnalysisStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum ConfigType {
  STRING
  NUMBER
  BOOLEAN
  JSON
}

// 用户表
model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  email     String?  @unique // 邮箱可选，支持微信注册
  password  String?  // 密码可选，支持微信登录
  phone     String?  @unique // 手机号
  wechatId  String?  @unique @map("wechat_id") // 微信openid
  wechatUnionId String? @map("wechat_union_id") // 微信unionid
  avatar    String?  // 头像URL
  nickname  String?  // 昵称
  gender    Int?     // 性别：0未知，1男，2女
  role      UserRole @default(USER)
  isActive  Boolean  @default(true)
  lastLoginAt DateTime? @map("last_login_at") // 最后登录时间
  loginCount Int @default(0) @map("login_count") // 登录次数
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 关系
  analysisTasks AnalysisTask[]
  apiLogs       ApiLog[]
  userSessions  UserSession[]

  @@map("users")
}

// 分析任务表
model AnalysisTask {
  id        Int                @id @default(autoincrement())
  userId    Int                @map("user_id")
  type      AnalysisType
  content   String?
  filePath  String?            @map("file_path")
  status    AnalysisStatus     @default(PENDING)
  result    String?            // SQLite使用String存储JSON
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")

  // 关联的用户
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("analysis_tasks")
}

// 违禁词库表
model ForbiddenWord {
  id        Int      @id @default(autoincrement())
  word      String
  category  String?
  severity  Int      @default(1) // 1: 低风险, 2: 中风险, 3: 高风险
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("forbidden_words")
}

// 系统配置表
model SystemConfig {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  type      ConfigType @default(STRING)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_configs")
}

// API调用日志表
model ApiLog {
  id         Int      @id @default(autoincrement())
  userId     Int?     @map("user_id")
  endpoint   String
  method     String
  statusCode Int      @map("status_code")
  duration   Int      // 毫秒
  userAgent  String?  @map("user_agent")
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  // 关联用户（可选）
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("api_logs")
}

// 用户会话表
model UserSession {
  id        String   @id @default(cuid())
  userId    Int      @map("user_id")
  token     String   @unique // JWT token或session token
  deviceInfo String? @map("device_info") // 设备信息
  ipAddress String?  @map("ip_address") // IP地址
  userAgent String?  @map("user_agent") // 用户代理
  isActive  Boolean  @default(true) @map("is_active")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // 关联用户
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_sessions")
}
