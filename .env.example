# 应用配置
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# 数据库配置
DATABASE_URL=postgresql://username:password@localhost:5432/beauty_ai
REDIS_URL=redis://localhost:6379

# JWT配置
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# AI服务配置
ALI_CLOUD_API_KEY=your-ali-cloud-api-key
ALI_CLOUD_API_SECRET=your-ali-cloud-api-secret
ALI_CLOUD_ENDPOINT=https://dashscope.aliyuncs.com/api/v1/

# 文件上传配置
UPLOAD_MAX_SIZE=10485760  # 10MB
UPLOAD_PATH=./uploads
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,webp

# 邮件配置 (可选)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# 日志配置
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# 缓存配置
CACHE_TTL=3600  # 1小时

# API限流配置
RATE_LIMIT_WINDOW=900000  # 15分钟
RATE_LIMIT_MAX=100  # 每15分钟最多100次请求