{
  "name": "api-integration-plugin",
  "version": "1.0.0",
  "description": "A modern, extensible API integration plugin inspired by API Dash",
  "main": "dist/index.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "type-check": "tsc --noEmit",
    "analyze": "npx vite-bundle-analyzer"
  },
  "keywords": [
    "api",
    "integration",
    "http",
    "rest",
    "graphql",
    "client",
    "testing",
    "codegen",
    "postman",
    "insomnia"
  ],
  "author": "API Integration Team",
  "license": "MIT",
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.8.0",
    "antd": "^5.2.0",
    "@ant-design/icons": "^5.0.0",
    "axios": "^1.3.0",
    "monaco-editor": "^0.36.0",
    "@monaco-editor/react": "^4.4.0",
    "highlight.js": "^11.7.0",
    "js-beautify": "^1.14.0",
    "lodash": "^4.17.21",
    "uuid": "^9.0.0",
    "dayjs": "^1.11.0",
    "zustand": "^4.3.0",
    "react-query": "^3.39.0",
    "react-hook-form": "^7.43.0",
    "yup": "^1.0.0",
    "@hookform/resolvers": "^2.9.0",
    "react-beautiful-dnd": "^13.1.0",
    "react-resizable-panels": "^0.0.55",
    "file-saver": "^2.0.5",
    "jszip": "^3.10.0",
    "xml-formatter": "^3.3.0",
    "yaml": "^2.2.0",
    "csv-parse": "^5.3.0",
    "prismjs": "^1.29.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/node": "^18.14.0",
    "@types/lodash": "^4.14.0",
    "@types/uuid": "^9.0.0",
    "@types/js-beautify": "^1.13.0",
    "@types/file-saver": "^2.0.5",
    "@types/react-beautiful-dnd": "^13.1.0",
    "@types/prismjs": "^1.26.0",
    "typescript": "^4.9.0",
    "vite": "^4.1.0",
    "@vitejs/plugin-react": "^3.1.0",
    "@vitejs/plugin-react-swc": "^3.0.0",
    "eslint": "^8.35.0",
    "@typescript-eslint/eslint-plugin": "^5.54.0",
    "@typescript-eslint/parser": "^5.54.0",
    "eslint-plugin-react": "^7.32.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.3.4",
    "prettier": "^2.8.0",

    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^14.5.1",

    "@playwright/test": "^1.31.0",


    "ts-jest": "^29.0.0",
    "vite-tsconfig-paths": "^4.0.0",
    "rollup-plugin-visualizer": "^5.9.0"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{css,md}": [
      "prettier --write"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}